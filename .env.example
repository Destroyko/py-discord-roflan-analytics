# Do not commit .env — copy this file to .env and fill in values.

# --- Required ---
DISCORD_BOT_TOKEN=
GUILD_ID=
STATS_CHANNEL_IDS=123456789012345678,987654321098765432

# --- Leaderboard ---
LEADERBOARD_EMOJIS=EBALO
LEADERBOARD_TIMEZONE=Europe/Moscow
LEADERBOARD_TOP_N=10
LEADERBOARD_CHANNEL_ID=
DATABASE_PATH=./data/leaderboard.db

# Optional: exclude channels or users from stats / TOP
IGNORE_CHANNEL_IDS=
EXCLUDED_USER_IDS=

# --- Bot scheduler ---
# Daily incremental sync for the current month (default 04:00 local)
DAILY_SYNC_ENABLED=true
DAILY_SYNC_HOUR=4
DAILY_SYNC_MINUTE=0

# Full recalc + embed on the 1st (default 10:00 local)
LEADERBOARD_MONTHLY_RUN_HOUR=10
LEADERBOARD_MONTHLY_RUN_MINUTE=0

# Roles allowed to run /recalculate_leaderboard (Administrator always can)
MANUAL_RECALC_ROLE_IDS=

# --- Rofler role reassignment (optional; off by default) ---
# true = monthly job + slash assign_roles; strip/assign by user IDs stored in SQLite
# (no Server Members Intent). First run: remove the role manually from non-winners.
ROLE_REASSIGN_ENABLED=false
# When ROLE_REASSIGN_ENABLED=true, fill all ROLE_* below (durkichi/roflinkichi channels ∈ STATS_CHANNEL_IDS)
# ROLE_ROFLER_ID=
# ROLE_NOTIFY_CHANNEL_ID=
# ROLE_ERROR_CHANNEL_ID=
# ROLE_DURKICHI_CHANNEL_ID=
# ROLE_ROFLINKICHI_CHANNEL_ID=
