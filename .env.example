# v2 (block A): official bot token — REQUIRED in .env, do not commit this file.
DISCORD_BOT_TOKEN=

# v1 only (deprecated in v2): user token for one-shot CLI.
# DISCORD_USER_TOKEN=

# Single guild to collect statistics from.
GUILD_ID=

# Comma-separated list of text channel IDs to scan.
STATS_CHANNEL_IDS=123456789012345678,987654321098765432

# Optional: channel IDs to exclude from STATS_CHANNEL_IDS.
IGNORE_CHANNEL_IDS=

# Optional: Discord user IDs excluded from scan, TOP, channel tops, and role stub.
EXCLUDED_USER_IDS=

# IANA timezone used to compute month boundaries (default Europe/Moscow).
LEADERBOARD_TIMEZONE=Europe/Moscow

# Monthly job: 1st of each month at this local time (default 10:00).
LEADERBOARD_MONTHLY_RUN_HOUR=10
LEADERBOARD_MONTHLY_RUN_MINUTE=0

# Daily incremental sync for the current month (default 04:00 local).
DAILY_SYNC_ENABLED=true
DAILY_SYNC_HOUR=4
DAILY_SYNC_MINUTE=0
# Pause every N message fetches when refreshing known posts (rate-limit friendly).
DAILY_SYNC_FETCH_BATCH_SIZE=25
DAILY_SYNC_MESSAGE_DELAY_SEC=0.05

# Emoji names counted for the leaderboard (comma-separated; sums per message).
# Legacy single value: LEADERBOARD_EMOJI=EBALO
LEADERBOARD_EMOJIS=EBALO

# How many rows to print in the terminal TOP list and guild-wide embed.
LEADERBOARD_TOP_N=10

# SQLite database path (source of truth for all leaderboard data).
DATABASE_PATH=./data/leaderboard.db

# v2: channel for leaderboard embed after bot job (optional for CLI-only).
LEADERBOARD_CHANNEL_ID=

# v2: roles allowed to use /recalculate_leaderboard (comma-separated).
# Administrator always has access. MANUAL_RECALC_ROLE_ID is a legacy single-ID alias.
MANUAL_RECALC_ROLE_IDS=
MANUAL_RECALC_ROLE_ID=

# --- Rofler role reassignment (optional; off by default) ---
# false = stats/embed only; no Server Members Intent required in Discord Portal.
# true  = monthly job and slash assign_roles; enable SERVER MEMBERS INTENT on the bot.
ROLE_REASSIGN_ENABLED=false
# Required when ROLE_REASSIGN_ENABLED=true; bot needs Manage Roles; bot role above Rofler.
ROLE_ROFLER_ID=
# Success message channel (TOP lists + clickable role/users).
ROLE_NOTIFY_CHANNEL_ID=
# Failure alerts (strip/assign/notify errors).
ROLE_ERROR_CHANNEL_ID=
# Stats channel for TOP-3 «Дуркичи» (must be in STATS_CHANNEL_IDS).
ROLE_DURKICHI_CHANNEL_ID=
ROLE_DURKICHI_TOP_N=3
# Stats channel for TOP-2 «Рофлинкичи» (must be in STATS_CHANNEL_IDS).
ROLE_ROFLINKICHI_CHANNEL_ID=
ROLE_ROFLINKICHI_TOP_N=2

# --- v2 block B: resilient scan (all optional, sane defaults) ---

# Rows buffered before each staging write.
SCAN_BATCH_SIZE=100

# Emit a progress event every N messages seen per channel (slash live updates).
SCAN_PROGRESS_EVERY=500

# Safety cap per channel; 0 = no limit. Hitting it marks the channel INCOMPLETE
# (the run will not commit until re-run/resumed without the cap).
SCAN_MAX_MESSAGES_PER_CHANNEL=0

# Fetch each message individually when it has no cached reactions (slower, rarely needed).
SCAN_FETCH_IF_EMPTY_REACTIONS=false

# Where the resumable checkpoint JSON is written (also acts as a per-month run lock).
SCAN_CHECKPOINT_DIR=./data

# Per-channel retry attempts on transient Discord errors (429/5xx).
SCAN_RETRY_MAX_ATTEMPTS=5

# Pause between channels to be gentle on rate limits.
SCAN_CHANNEL_DELAY_SEC=0.5

# true (default): any failed/skipped/incomplete channel blocks the commit.
# false (debug): missing channels are skipped instead of failing the run.
SCAN_STRICT_CHANNELS=true
